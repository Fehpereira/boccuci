---
const images = [
  { title: 'Brilho e profundidade', category: 'Polimento' },
  { title: 'Precisão nos detalhes', category: 'Detalhamento' },
  { title: 'Acabamento premium', category: 'Vitrificação' },
  { title: 'Cuidado interno', category: 'Higienização' },
  { title: 'Proteção e performance', category: 'Proteção' },
];
---

<section id="galeria" class="relative py-16 md:py-28 bg-boc-black-soft grain-overlay">
  <div class="relative z-10 max-w-[1180px] mx-auto px-5 md:px-8 lg:px-16">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-12 md:mb-16">
      <div class="font-heading text-xs uppercase tracking-boc-wider text-boc-orange font-semibold mb-4">
        Galeria
      </div>
      
      <h2 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl tracking-boc-tight text-boc-white leading-tight mb-6">
        Resultados que falam por si.
      </h2>
      
      <div class="w-16 h-1 bg-boc-orange mx-auto" />
    </div>
    
    <!-- Gallery Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
      {images.map((image, index) => (
        <div class={`group relative overflow-hidden rounded-boc-lg border border-white/10 hover:border-boc-orange/40 transition-all duration-250 ${index === 0 ? 'col-span-2 md:col-span-2 row-span-2' : ''}`}>
          <!-- Placeholder -->
          <div class={`bg-gradient-to-br from-boc-charcoal to-boc-black ${index === 0 ? 'aspect-square md:aspect-auto md:h-full' : 'aspect-square'}`}>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-16 h-16 md:w-20 md:h-20 border-2 border-boc-orange/20 rotate-45 flex items-center justify-center">
                <span class="font-display font-bold text-xl md:text-2xl text-boc-orange/40 -rotate-45">B</span>
              </div>
            </div>
          </div>
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-boc-black/90 via-boc-black/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-250" />
          
          <!-- Content -->
          <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
            <div class="font-heading text-xs uppercase tracking-boc-wider text-boc-orange mb-1">
              {image.category}
            </div>
            <h3 class="font-heading font-semibold text-base md:text-lg text-boc-white">
              {image.title}
            </h3>
          </div>
          
          <!-- Hover Accent -->
          <div class="absolute top-4 right-4 w-8 h-8 border border-boc-orange/0 group-hover:border-boc-orange/60 rounded-boc-sm transition-all duration-250" />
        </div>
      ))}
    </div>
  </div>
</section>